# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── LLM & Embeddings (via OpenRouter) ───
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small

# ─── MCP Server Access Key ───
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OPEN_BRAIN_ACCESS_KEY=your-access-key

# ─── Connectors (optional — only set what you use) ───

# Notion
NOTION_API_TOKEN=ntn_your-token
NOTION_DATABASE_ID=your-database-id

# YouTube (no API key needed — uses yt-dlp)
YOUTUBE_PLAYLIST_URL=https://www.youtube.com/playlist?list=your-playlist-id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_USER_ID=your-user-id
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Resend Email Capture
RESEND_API_KEY=re_your-key
RESEND_WEBHOOK_SECRET=whsec_your-secret

# ─── Local Embeddings (optional — LM Studio) ───
LMSTUDIO_EMBED_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_EMBED_API_KEY=lmstudio-local
LMSTUDIO_EMBED_MODEL_1536=your-local-model
